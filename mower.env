# Modify this file with your own values.

# MQTT broker connection
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# MQTT topic prefix used for all published/subscribed topics
MOWER_BASE_TOPIC=mower_ble

# How often (seconds) to poll the mower. 60 is a sensible default — don't go much lower.
MOWER_POLL=60

# Your mower's Bluetooth MAC address.
# Leave blank or set to AA:BB:CC:DD:EE:FF to enable BLE autodiscovery (detects the first nearby mower).
MOWER_ADDRESS=AA:BB:CC:DD:EE:FF

# The PIN configured on your mower (same PIN used in the official Gardena app).
# Note: For Bluetooth pairing/bonding, the PIN must be entered physically on the mower
# using its button keypad. The buttons map to digits as follows:
#   1 = Power button
#   2 = Calendar button
#   3 = Start button
#   4 = Home button
# Example: If your PIN is 1423, you would physically press:
#   Power (1) -> Home (4) -> Calendar (2) -> Start (3)
MOWER_PIN=1234

# Optional logging settings (LOG_LEVEL can be DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
# LOG_FILE=/app/logs/mower.log
